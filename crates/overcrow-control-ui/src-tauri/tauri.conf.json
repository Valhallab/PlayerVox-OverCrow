{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlayerVox OverCrow",
  "version": "0.1.0-pre-alpha.2",
  "identifier": "com.playervox.OverCrow",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PlayerVox OverCrow",
        "width": 1040,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; connect-src ipc: http://ipc.localhost; form-action 'none'; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self'; style-src 'self'"
    }
  },
  "bundle": {
    "active": false
  }
}
